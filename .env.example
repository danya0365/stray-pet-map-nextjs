# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase Service Role Key (ใช้เฉพาะบน server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Database URL for direct database access (ใช้สำหรับ migrations)
# DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=http://straypetmap.online
NEXT_PUBLIC_APP_NAME="Stray Pet Map"

# Google OAuth Configuration (Required for Google Sign In)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=