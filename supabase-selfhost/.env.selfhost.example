# ============================================
# 🔧 Self-Hosted Supabase — Next.js Environment
# ============================================
# ใช้แทน .env.production.supabase.local
# ค่าด้านล่างได้จาก /opt/supabase/.credentials หลังรัน setup-supabase.sh
# ============================================

# Supabase Configuration (Self-Hosted)
NEXT_PUBLIC_SUPABASE_URL="https://supabase.social-generator.vibify.site"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<ANON_KEY จาก .credentials>"
SUPABASE_SERVICE_ROLE_KEY="<SERVICE_ROLE_KEY จาก .credentials>"

# Database
POSTGRES_PASSWORD="<POSTGRES_PASSWORD จาก .credentials>"

# Direct Database Access (ผ่าน Supavisor)
# Session mode (port 5432):
# DATABASE_URL=postgresql://postgres.your-tenant-id:<POSTGRES_PASSWORD>@supabase.social-generator.vibify.site:5432/postgres
# Pooled mode (port 6543):
# DATABASE_URL=postgresql://postgres.your-tenant-id:<POSTGRES_PASSWORD>@supabase.social-generator.vibify.site:6543/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=https://social-generator.vibify.site
NEXT_PUBLIC_APP_NAME="AI Content Creator"

# Colyseus Multiplayer Server Configuration
NEXT_PUBLIC_COLYSEUS_HOST=localhost
NEXT_PUBLIC_COLYSEUS_PORT=2567
NEXT_PUBLIC_COLYSEUS_SECURE=false
COLYSEUS_PORT=2567

# ========================================
# Auth Configuration - Login Methods
# ========================================
NEXT_PUBLIC_AUTH_EMAIL_ENABLED=true
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=false
NEXT_PUBLIC_AUTH_PHONE_ENABLED=false
NEXT_PUBLIC_AUTH_OAUTH_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=false
NEXT_PUBLIC_AUTH_GITHUB_ENABLED=false
NEXT_PUBLIC_AUTH_LINE_ENABLED=false

# ========================================
# Auth Features
# ========================================
NEXT_PUBLIC_AUTH_FORGOT_PASSWORD_ENABLED=true
NEXT_PUBLIC_AUTH_EMAIL_VERIFICATION_ENABLED=true
NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# ============================================
# AI Content Creator Configuration
# ============================================
AI_PROVIDER=groq
AI_IMAGE_PROVIDER=wavespeed
GROQ_API_KEY=<your-groq-api-key>
GEMINI_API_KEY=<your-gemini-api-key>
WAVESPEED_API_KEY=<your-wavespeed-api-key>
WAVESPEED_CONTENT_MODEL=meta-llama/llama-3.1-70b-instruct
WAVESPEED_IMAGE_MODEL=wavespeed-ai/flux-dev

# Cron Job Secret
CRON_SECRET=<your-secure-cron-secret>
